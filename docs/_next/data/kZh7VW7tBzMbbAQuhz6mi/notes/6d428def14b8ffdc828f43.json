{"pageProps":{"note":{"id":"6d428def14b8ffdc828f43","title":"AI 打印机固件 — 项目交接资料","desc":"","updated":1780371367064,"created":1780371330029,"custom":{},"fname":"开发记录.项目交接资料","type":"note","vault":{"fsPath":"notes","name":"Dendron"},"contentHash":"36cf4dd75875b22dc5cd1c19fd3d0f96","links":[{"type":"wiki","from":{"fname":"开发记录.项目交接资料","id":"6d428def14b8ffdc828f43","vaultName":"Dendron"},"value":"开发记录.项目开发记录总纲","position":{"start":{"line":9,"column":31,"offset":216},"end":{"line":9,"column":48,"offset":233},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"开发记录.项目开发记录总纲"}},{"type":"wiki","from":{"fname":"开发记录.项目交接资料","id":"6d428def14b8ffdc828f43","vaultName":"Dendron"},"value":"阶段性开发总结","position":{"start":{"line":9,"column":63,"offset":248},"end":{"line":9,"column":74,"offset":259},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"阶段性开发总结"}},{"type":"wiki","from":{"fname":"开发记录.项目交接资料","id":"6d428def14b8ffdc828f43","vaultName":"Dendron"},"value":"开发记录.打印机参数排列组合记录","position":{"start":{"line":17,"column":40,"offset":379},"end":{"line":17,"column":60,"offset":399},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"开发记录.打印机参数排列组合记录"}},{"type":"wiki","from":{"fname":"开发记录.项目交接资料","id":"6d428def14b8ffdc828f43","vaultName":"Dendron"},"value":"开发记录.BK7252n-LVGL多语言开发指南","position":{"start":{"line":21,"column":92,"offset":1006},"end":{"line":21,"column":120,"offset":1034},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"开发记录.BK7252n-LVGL多语言开发指南"}},{"type":"wiki","from":{"fname":"开发记录.项目交接资料","id":"6d428def14b8ffdc828f43","vaultName":"Dendron"},"value":"开发记录.项目开发记录总纲","position":{"start":{"line":42,"column":16,"offset":1692},"end":{"line":42,"column":33,"offset":1709},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"开发记录.项目开发记录总纲"}},{"type":"wiki","from":{"fname":"开发记录.项目交接资料","id":"6d428def14b8ffdc828f43","vaultName":"Dendron"},"value":"开发记录.prn_tune串口调参命令","position":{"start":{"line":52,"column":12,"offset":1880},"end":{"line":