,"end":{"line":88,"column":132,"offset":3144},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"开发记录.2026-05-07_LVGL桌面二维码与WS预览UI开发总结"}},{"type":"wiki","from":{"fname":"开发记录.项目交接资料","id":"6d428def14b8ffdc828f43","vaultName":"Dendron"},"value":"开发记录.BUG-001-按键_Data_Abort_共享缓冲竞态","position":{"start":{"line":116,"column":56,"offset":4014},"end":{"line":116,"column":93,"offset":4051},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"开发记录.BUG-001-按键_Data_Abort_共享缓冲竞态"}},{"type":"wiki","from":{"fname":"开发记录.项目交接资料","id":"6d428def14b8ffdc828f43","vaultName":"Dendron"},"value":"开发记录.AI打印机应用架构评估与优化方向","position":{"start":{"line":117,"column":42,"offset":4095},"end":{"line":117,"column":67,"offset":4120},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"开发记录.AI打印机应用架构评估与优化方向"}},{"type":"wiki","from":{"fname":"开发记录.项目交接资料","id":"6d428def14b8ffdc828f43","vaultName":"Dendron"},"value":"开发记录.2026-05-07_热敏打印机驱动算法分析与工作记录","position":{"start":{"line":118,"column":58,"offset":4180},"end":{"line":118,"column":94,"offset":4216},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"开发记录.2026-05-07_热敏打印机驱动算法分析与工作记录"}},{"type":"wiki","from":{"fname":"开发记录.项目交接资料","id":"6d428def14b8ffdc828f43","vaultName":"Dendron"},"value":"开发记录.bk7252n-烧录教程","position":{"start":{"line":129,"column":62,"offset":4384},"end":{"line":129,"column":83,"offset":4405},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"开发记录.bk7252n-烧录教程"}},{"type":"wiki","from":{"fname":"开发记录.项目交接资料","id":"6d428def14b8ffdc828f43","vaultName":"Dendron"},"value":"开发记录.打印机参数排列组合记录","position":{"start":{"line":154,"column":25,"offset":4860},"end":{"line":154,"column":45,"offset":4880},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"开发记录.打印机参数排列组合记录"}},{"from":{"fname":"开发记录.项目开发记录总纲","id":"62ff4545e5f1373c5cfe01","vaultName":"Dendron"},"type":"backlink","position":{"start":{"line":97,"column":39,"offset":6491},"end":{"line":97,"column":54,"offset":6506},"indent":[]},"value":"开发记录.项目交接资料"}],"anchors":{"ai-打印机固件--项目交接资料":{"type":"header","text":"AI 打印机固件 — 项目交接资料","value":"ai-打印机固件--项目交接资料","line":8,"column":0,"depth":1},"1-交接摘要接手方必读":{"type":"header","text":"1. 交接摘要（接手方必读）","value":"1-交接摘要接手方必读","line":19,"column":0,"depth":2},"2-工程与模块归属":{"type":"header","text":"2. 工程与模块归属","value":"2-工程与模块归属","line":33,"column":0,"depth":2},"3-打印模块交接要点":{"type":"header","text":"3. 打印模块交接要点","value":"3-打印模块交接要点","line":52,"column":0,"depth":2},"31-串口调参msh":{"type":"header","text":"3.1 串口调参（MSH）","value":"31-串口调参msh","line":54,"column":0,"depth":3},"32-代码锚点":{"type":"header","text":"3.2 代码锚点","value":"32-代码锚点","line":60,"column":0,"depth":3},"33-接手方建议":{"type":"header","text":"3.3 接手方建议","value":"33-接手方建议","line":68,"column":0,"depth":3},"4-多语言模块交接要点":{"type":"header","text":"4. 多语言模块交接要点","value":"4-多语言模块交接要点","line":76,"column":0,"depth":2},"5-ui-模块交接要点":{"type":"header","text":"5. UI 模块交接要点","value":"5-ui-模块交接要点","line":90,"column":0,"depth":2},"6-ota-交接要点待测":{"type":"header","text":"6. OTA 交接要点（待测）","value":"6-ota-交接要点待测","line":98,"column":0,"depth":2},"61-入口":{"type":"header","text":"6.1 入口","value":"61-入口","line":100,"column":0,"depth":3},"62-建议测试清单接手方执行并勾选":{"type":"header","text":"6.2 建议测试清单（接手方执行并勾选）","value":"62-建议测试清单接手方执行并勾选","line":109,"column":0,"depth":3},"7-已知风险与跟踪项":{"type":"header","text":"7. 已知风险与跟踪项","value":"7-已知风险与跟踪项","line":118,"column":0,"depth":2},"8-环境与产物":{"type":"header","text":"8. 环境与产物","value":"8-环境与产物","line":128,"column":0,"depth":2},"9-串口命令速查":{"type":"header","text":"9. 串口命令速查","value":"9-串口命令速查","line":139,"column":0,"depth":2},"10-接手检查清单通用":{"type":"header","text":"10. 接手检查清单（通用）","value":"10-接手检查清单通用","line":149,"column":0,"depth":2}},"children":[],"parent":"jxzspjsfkjpyzxdrn5ntdy7","data":{}},"body":"<h1 id=\"ai-打印机固件--项目交接资料\">AI 打印机固件 — 项目交接资料<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#ai-打印机固件--项目交接资料\"></a></h1>\n<h1 id=\"ai-打印机固件--项目交接资料-1\">AI 打印机固件 — 项目交接资料<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#ai-打印机固件--项目交接资料-1\"></a></h1>\n<p><strong>文档用途</strong>：研发 / 测试接手时的单一入口说明 — 汇总近期实机结论、代码位置、串口命令与待办验证项。<br>\n<strong>工程路径</strong>：<code>bk7252n_sdk-SDK_3.0.76.1_witch_lcd</code><br>\n<strong>平台</strong>：BK7252N + RT-Thread + LVGL<br>\n<strong>整理日期</strong>：2026-05-07  </p>\n<p><strong>关联索引</strong>：专题拆分纪要见同目录下各篇记录；总索引见 <a href=\"/notes/62ff4545e5f1373c5cfe01\">AI 打印机固件 — 项目开发记录总纲</a>。同期口述整理亦见上一级目录 <a href=\"/notes/9fd53d681f5e8043762252\">阶段性开发总结：打印标定、驱动算法、多语言、UI 与 OTA</a>（与本文件要点一致，可作备份入口）。</p>\n<hr>\n<h2 id=\"1-交接摘要接手方必读\">1. 交接摘要（接手方必读）<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#1-交接摘要接手方必读\"></a></h2>\n<div class=\"table-responsive\">\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<table><thead><tr><th>维度</th><th>状态与结论</th></tr></thead><tbody><tr><td><strong>打印参数</strong></td><td>实机累计不少于约 <strong>500 张</strong> 试验；台账见 <a href=\"/notes/69fab073dcdd31f425755e\">打印机参数排列组合记录</a>。文生图侧 <strong>非整幅高密度全图</strong>，图案偏稀疏，当前参数 <strong>可勉强覆盖现有客户场景</strong>。六模式端到端约 <strong>8 s～20 s</strong>，常见操作 <strong>多在十几秒量级</strong>（含业务链路与打印，不单指 GPIO 送数）。</td></tr><tr><td><strong>驱动与瓶颈</strong></td><td><strong>GPIO 模拟 SPI 移位送数</strong> 约在 <strong>秒级</strong>（如 384×384 量级），<strong>不是整机十几秒级的主因</strong>。<strong>步进节奏 + 加热能量（密度、脉宽、多脉冲）</strong> 才是速度与硬件风险的主轴。</td></tr><tr><td><strong>双驱动路径</strong></td><td><code>thermal_printer.c</code> 内保留 <strong>分段（legacy）</strong> 与 <strong>整行 + 多脉冲（DevTerm / whole）</strong> 两类策略；串口 <strong><code>prn_tune</code></strong> 可切换 <code>heatmode whole \\| seg</code>、<code>heatpulse</code> 等（以 <code>prn_tune help</code> 为准）。</td></tr><tr><td><strong>硬件风险</strong></td><td>新路径在多脉冲、偏高能量下 <strong>曾损坏 2 台设备</strong>；接手方 <strong>务必保守起步</strong>，依赖 <strong><code>prn_tune set stop</code> / <code>resume</code> 等温控</strong>，避免无设备环境下盲目加压。</td></tr><tr><td><strong>多语言</strong></td><td><strong>21 种</strong>（语言 ID <strong>0～20</strong>），与 <code>g_device_lang_table[]</code> 顺序绑定；串口 <strong><code>cfglang</code></strong>；维护指南见 <a href=\"/notes/86d6a17041618132f76abf\">BK7252n 上 LVGL 多语言界面开发指南</a>。</td></tr><tr><td><strong>UI</strong></td><td>LVGL 可做动效，但须 <strong>控制 CPU / 内存 / 刷新</strong>；电池、WiFi、语音反馈等倾向 <strong>程序化绘图</strong> 减资源占用。当前桌面为第一版可用方案。</td></tr><tr><td><strong>OTA</strong></td><td>代码 <strong>已接入</strong>（HTTP Shell + MQTT <code>otaCheck</code> 触发）；作者 <strong>未完成完整回归</strong>，需接手方 <strong>安排专项测试</strong>。</td></tr></tbody></table></div>\n<hr>\n<h2 id=\"2-工程与模块归属\">2. 工程与模块归属<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#2-工程与模块归属\"></a></h2>\n<pre><code>applications/\n├── main.c                    # 启动编排\n├── Printer/thermal_printer.c # 热敏打印主实现、prn_tune\n├── mqtt_backend/             # MQTT、device_config（cfglang）、二进制收图\n├── pages/lv_example_meter.c  # LVGL 主桌面与二级 UI\n├── pages/ui_strings.*        # 多语言文案与字体选择\n├── OTA_Upgrade/              # OTA 下载与刷写线程\n├── audio/                    # 语音上传与结果等待\n├── button_control/           # 按键（含长按语音、二维码等）\n└── ble_provision/            # 配网相关\n</code></pre>\n<p>详细「文档 ? 代码」映射见 <a href=\"/notes/62ff4545e5f1373c5cfe01\">AI 打印机固件 — 项目开发记录总纲</a> §1。</p>\n<hr>\n<h2 id=\"3-打印模块交接要点\">3. 打印模块交接要点<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#3-打印模块交接要点\"></a></h2>\n<h3 id=\"31-串口调参msh\">3.1 串口调参（MSH）<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#31-串口调参msh\"></a></h3>\n<ul>\n<li><strong>前提</strong>：<code>RT_USING_FINSH</code> 开启；打印机已初始化；<strong>打印进行中</strong>会拒绝修改（<code>busy printing</code>）。</li>\n<li><strong>命令</strong>：<code>prn_tune help</code> / <code>prn_tune show</code>。</li>\n<li><strong>说明文档</strong>：<a href=\"/notes/e219878f58bd997c455ca8\">prn_tune 串口调参命令说明</a>。</li>\n</ul>\n<h3 id=\"32-代码锚点\">3.2 代码锚点<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#32-代码锚点\"></a></h3>\n<div class=\"table-responsive\">\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<table><thead><tr><th>内容</th><th>路径</th></tr></thead><tbody><tr><td>调参命令</td><td><code>applications/Printer/thermal_printer.c</code>：<code>prn_tune_cmd</code>，<code>MSH_CMD_EXPORT_ALIAS(..., prn_tune, ...)</code></td></tr><tr><td>整行 / 分段</td><td>同文件：<code>print_line_whole</code>、<code>print_line_segmented</code>、<code>heat_layout</code>、<code>whole_line_strobe_pulses</code></td></tr><tr><td>算法综述</td><td><a href=\"/notes/0a6f1fae03382ed23a61e4\">热敏打印机驱动算法分析与工作记录</a></td></tr></tbody></table></div>\n<h3 id=\"33-接手方建议\">3.3 接手方建议<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#33-接手方建议\"></a></h3>\n<ol>\n<li>回现场有设备后，从 <strong><code>preset L1～L4</code> 或文档保守组合</strong> 起步，再对比 <code>whole</code> + 低 <code>heatpulse</code>。  </li>\n<li>任何激进试验前确认 <strong>测温周期</strong>（如 <code>prn_tune set check</code>）与 <strong>停打温度</strong> 生效。  </li>\n<li>参考开源思路的目录（若仓库仍存在）：<code>开源打印机代码/DevTerm/Code/thermal_printer/</code>（以当前仓库实际路径为准）。</li>\n</ol>\n<hr>\n<h2 id=\"4-多语言模块交接要点\">4. 多语言模块交接要点<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#4-多语言模块交接要点\"></a></h2>\n<div class=\"table-responsive\">\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<table><thead><tr><th>项目</th><th>说明</th></tr></thead><tbody><tr><td>语言数量</td><td>21（ID <code>0</code>～<code>20</code>，与 <code>DEVICE_CFG_LANG_MAX_ID</code> 一致）</td></tr><tr><td>Shell</td><td><code>cfglang</code> —— <code>applications/mqtt_backend/device_config.c</code>：<code>cfglang()</code>，<code>MSH_CMD_EXPORT</code></td></tr><tr><td>语言表</td><td>同文件 <code>g_device_lang_table[]</code>；<strong>顺序必须与</strong> <code>ui_strings</code> / UI 枚举 <strong>严格一致</strong></td></tr><tr><td>维护指南</td><td><a href=\"/notes/86d6a17041618132f76abf\">BK7252n 上 LVGL 多语言界面开发指南</a>、<a href=\"/notes/f068cc85f553b7fa6f808b\">多语言字库与稳定性开发纪要</a></td></tr><tr><td>字体生成脚本</td><td><code>tools/scripts/gen_lv_font_simsun_16_cjk.py</code>、<code>gen_lv_font_ui_i18n_14.py</code></td></tr></tbody></table></div>\n<p>文案批量对齐建议 continues 借助工具辅助；人工逐语种比对成本高。</p>\n<hr>\n<h2 id=\"5-ui-模块交接要点\">5. UI 模块交接要点<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#5-ui-模块交接要点\"></a></h2>\n<ul>\n<li><strong>原则</strong>：特效可做，避免高开销动画与大图资源堆砌。  </li>\n<li><strong>状态图标</strong>：电池、WiFi、语音反馈等 —— LVGL 绘制为主。  </li>\n<li><strong>详细纪要</strong>：<a href=\"/notes/c82a45ea03c9396b83d2e6\">LVGL 主桌面六模式与语音卡片 UI 移植总结</a>、<a href=\"/notes/0faf28cd9ea6b2133119c7\">LVGL 模式卡片、六模式图标资源与动效 — 开发总结</a>、<a href=\"/notes/124fc2bd28f4ff32a71b93\">BK7252n LVGL：桌面、二维码页与 MQTT 图片预览 UI 开发总结</a>。</li>\n</ul>\n<hr>\n<h2 id=\"6-ota-交接要点待测\">6. OTA 交接要点（待测）<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#6-ota-交接要点待测\"></a></h2>\n<h3 id=\"61-入口\">6.1 入口<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#61-入口\"></a></h3>\n<div class=\"table-responsive\">\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<table><thead><tr><th>方式</th><th>路径 / 说明</th></tr></thead><tbody><tr><td>HTTP Shell</td><td><code>applications/OTA_Upgrade/OTA_Upgrade.c</code>：<code>ota_upgrade_http [url]</code> → <code>ota_upgrade_start_thread</code> → <code>ota_upgrade_download_fw</code></td></tr><tr><td>MQTT</td><td><code>applications/mqtt_backend/mqtt_backend_message.c</code>：解析有效 <code>download_url</code> 后 <code>ota_upgrade_start_thread</code></td></tr><tr><td>依赖</td><td>需 <code>PKG_USING_WEBCLIENT</code> 与 <code>PKG_USING_RT_OTA</code>（见 <code>OTA_Upgrade.c</code> 条件编译）</td></tr><tr><td>分区</td><td><code>config/fal_cfg.h</code>、<code>fal</code> 分区与 <code>RT_BK_DL_PART_NAME</code>、<code>RT_BK_APP_NAME</code> 一致</td></tr></tbody></table></div>\n<h3 id=\"62-建议测试清单接手方执行并勾选\">6.2 建议测试清单（接手方执行并勾选）<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#62-建议测试清单接手方执行并勾选\"></a></h3>\n<ul class=\"contains-task-list\">\n<li class=\"task-list-item\"><input type=\"checkbox\" disabled> 使用可控 <strong>HTTP 固件 URL</strong> 执行 <code>ota_upgrade_http</code>，验证下载、进度与重启后版本号。  </li>\n<li class=\"task-list-item\"><input type=\"checkbox\" disabled> 走 <strong>MQTT <code>otaCheck</code>（或等价 payload）</strong> 全链路触发 OTA。  </li>\n<li class=\"task-list-item\"><input type=\"checkbox\" disabled> <strong>弱网 / 中途断电</strong> 等异常（按项目测试规范记录日志）。  </li>\n<li class=\"task-list-item\"><input type=\"checkbox\" disabled> 失败场景保留：<strong>HTTP 状态、content_length、分区名与偏移、Flash 错误码</strong>。</li>\n</ul>\n<hr>\n<h2 id=\"7-已知风险与跟踪项\">7. 已知风险与跟踪项<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#7-已知风险与跟踪项\"></a></h2>\n<div class=\"table-responsive\">\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<table><thead><tr><th>ID / 主题</th><th>说明</th><th>文档或代码</th></tr></thead><tbody><tr><td>BUG-001</td><td>MQTT 二进制共享缓冲与打印 / LVGL 异步预览的 <strong>并发覆盖</strong> 风险</td><td><a href=\"/notes/7e757dba3afa1d4361d951\">BUG-001：按键极限操作触发 Data Abort / 意外重启</a></td></tr><tr><td>架构与安全</td><td>MQTT 凭证、启动阻塞、打印 bit-bang 占用等</td><td><a href=\"/notes/4b4a79d037a6f442a84233\">AI打印机应用架构评估与优化方向</a></td></tr><tr><td>打印算法</td><td><code>delay_us</code> 与主频耦合、<code>dense_boost</code> 与 <code>gshape</code> 叠加等</td><td><a href=\"/notes/0a6f1fae03382ed23a61e4\">热敏打印机驱动算法分析与工作记录</a></td></tr></tbody></table></div>\n<hr>\n<h2 id=\"8-环境与产物\">8. 环境与产物<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#8-环境与产物\"></a></h2>\n<pre class=\"language-bash\"><code class=\"language-bash\"><span class=\"token builtin class-name\">export</span> <span class=\"token assign-left variable\">RTT_EXEC_PATH</span><span class=\"token operator\">=</span><span class=\"token operator\">&#x3C;</span>arm-none-eabi-gcc<span class=\"token operator\">></span>/bin/\nscons --beken<span class=\"token operator\">=</span>bk7252n -j8\n</code></pre>\n<p>产物目录：<code>out/</code>（如 <code>all_4M.*.bin</code>、<code>rtthread_uart_4M.*.bin</code>）。烧录步骤见 <a href=\"/notes/40a0c1d0224426bb0700ea\">BK7252N 烧录教程（基于当前工程产物）</a>。</p>\n<hr>\n<h2 id=\"9-串口命令速查\">9. 串口命令速查<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#9-串口命令速查\"></a></h2>\n<div class=\"table-responsive\">\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<table><thead><tr><th>命令</th><th>用途</th></tr></thead><tbody><tr><td><code>prn_tune help</code></td><td>热敏打印运行时调参</td></tr><tr><td><code>cfglang</code></td><td>查看或设置 UI 语言（<code>0-20</code> 或 ISO 代码）</td></tr><tr><td><code>ota_upgrade_http [url]</code></td><td>OTA（需编译开启相应包）</td></tr></tbody></table></div>\n<hr>\n<h2 id=\"10-接手检查清单通用\">10. 接手检查清单（通用）<a aria-hidden=\"true\" class=\"anchor-heading icon-link\" href=\"#10-接手检查清单通用\"></a></h2>\n<ul class=\"contains-task-list\">\n<li class=\"task-list-item\"><input type=\"checkbox\" disabled> 已阅读 §1 摘要与 §7 风险。  </li>\n<li class=\"task-list-item\"><input type=\"checkbox\" disabled> 本地或 CI 能 <strong>完整编译</strong> 当前分支。  </li>\n<li class=\"task-list-item\"><input type=\"checkbox\" disabled> 有一份 <strong>与分区表匹配</strong> 的烧录流程说明（见烧录教程）。  </li>\n<li class=\"task-list-item\"><input type=\"checkbox\" disabled> 打印：<strong>prn_tune show</strong> baseline 存档后再做对比试验。  </li>\n<li class=\"task-list-item\"><input type=\"checkbox\" disabled> 多语言：修改语言表后执行 <strong>ID / 枚举 / 表行</strong> 三方一致性检查。  </li>\n<li class=\"task-list-item\"><input type=\"checkbox\" disabled> OTA：按 §6.2 完成或排期 <strong>专项回归</strong>。  </li>\n</ul>\n<hr>\n<p><em>数值与默认行为以当前分支源码为准；历史参数以 <a href=\"/notes/69fab073dcdd31f425755e\">打印机参数排列组合记录</a> 与各 dated 纪要为考古参考。</em></p>\n<hr>\n<strong>Backlinks</strong>\n<ul>\n<li><a href=\"/notes/62ff4545e5f1373c5cfe01\">AI 打印机固件 — 项目开发记录总纲</a></li>\n</ul>","noteIndex":{"id":"root","title":"root","desc":"BK7252N AI ��ӡ���̼��ĵ���","updated":1780371367067,"created":1595961348801,"custom":{"nav_order":0,"permalink":"/"},"fname":"root","type":"note","vault":{"fsPath":"notes","name":"Dendron"},"contentHash":"01a79b7e7f0264a5734e0abe50acd9de","links":[{"type":"wiki","from":{"fname":"root","id":"root","vaultName":"Dendron"},"value":"������¼.��Ŀ������¼�ܸ�","position":{"start":{"line":8,"column":3,"offset":96},"end":{"line":8,"column":28,"offset":121},"indent":[]},"xvault":false,"sameFile":false,"to":{"fname":"������¼.��Ŀ������¼�ܸ�"}},{"type":"wiki","from":{"fname":"root","id":"root","vaultName":"Dendron"},"